#!/usr/bin/env bash
set -euo pipefail

vault="${1:-/home/goringich/Desktop/Obsidian}"

if ! git -C "$vault" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not a git repository: $vault" >&2
  exit 1
fi

git -C "$vault" status --short --untracked-files=all \
  | awk '
      {
        status = substr($0, 1, 2)
        path = substr($0, 4)
        if (path ~ /\.md$/ &&
            path !~ /^\.obsidian\// &&
            path !~ /^\.smart-env\// &&
            path !~ /^\.trash\//) {
          print status "\t" path
        }
      }
    ' \
  | sort
