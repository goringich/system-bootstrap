#!/usr/bin/env python3
import json
import re
import subprocess
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path

SESSIONS_ROOT = Path("/home/goringich/.copilot/session-state")
OUT_ROOT = Path("/home/goringich/Desktop/Obsidian/ИИ/Copilot/Conversations")
VAULT_ROOT = Path("/home/goringich/Desktop/Obsidian")
STATE_FILE = Path("/home/goringich/.local/state/copilot-obsidian-sync/state.json")
MAX_CHARS_PER_PART = 25000
EXPORT_FORMAT_VERSION = 1

LINK_RE = re.compile(r"\[([^\]]+)\]\(([^)]+)\)")
CYRILLIC_MAP = {
    "а": "a", "б": "b", "в": "v", "г": "g", "д": "d", "е": "e", "ё": "e", "ж": "zh",
    "з": "z", "и": "i", "й": "y", "к": "k", "л": "l", "м": "m", "н": "n", "о": "o",
    "п": "p", "р": "r", "с": "s", "т": "t", "у": "u", "ф": "f", "х": "h", "ц": "ts",
    "ч": "ch", "ш": "sh", "щ": "sch", "ъ": "", "ы": "y", "ь": "", "э": "e", "ю": "yu",
    "я": "ya",
}


@dataclass
class Msg:
    role: str
    text: str
    ts: str


def cleanup_text(text: str) -> str:
    return re.sub(r"\s+", " ", text.strip())


def clip_text(text: str, max_chars: int = 1800) -> str:
    text = text.strip()
    if len(text) <= max_chars:
        return text
    return f"{text[:max_chars].rstrip()}\n\n[truncated]"


def slugify(text: str, max_len: int = 64) -> str:
    out = []
    for ch in text.lower():
        if "a" <= ch <= "z" or "0" <= ch <= "9":
            out.append(ch)
            continue
        if ch in CYRILLIC_MAP:
            out.append(CYRILLIC_MAP[ch])
            continue
        if ch in (' ', '-', '_', '/', '\\', '.', ',', ':', ';', '!', '?', '(', ')', '[', ']', '{', '}', '+', '=', '"', "'", '`'):
            out.append("-")
    slug = re.sub(r"-+", "-", "".join(out)).strip("-")
    if not slug:
        slug = "conversation"
    return slug[:max_len].strip("-") or "conversation"


def sanitize_links(text: str) -> str:
    def _repl(match):
        label = match.group(1).strip()
        target = match.group(2).strip()
        if target.startswith("#"):
            return label
        p = Path(target)
        try:
            resolved = p.resolve() if p.is_absolute() else (VAULT_ROOT / p).resolve()
        except Exception:
            resolved = None
        if resolved is not None:
            try:
                rel = resolved.relative_to(VAULT_ROOT)
                if rel.suffix.lower() == ".md":
                    return f"[[{rel.with_suffix('').as_posix()}|{label}]]"
            except Exception:
                pass
        return label if label == target else f"{label} ({target})"

    return LINK_RE.sub(_repl, text)


def pick_topic(messages: list[Msg]) -> str:
    for msg in messages:
        if msg.role == "user":
            text = cleanup_text(msg.text)
            if text:
                return text[:90]
    return "conversation"


def build_turns(messages: list[Msg]) -> list[dict]:
    turns = []
    current = None
    for msg in messages:
        if msg.role == "user":
            text = cleanup_text(msg.text)
            if not text:
                continue
            if current is not None:
                turns.append(current)
            current = {"q": msg.text, "q_ts": msg.ts, "a": [], "a_ts": []}
            continue
        if msg.role == "assistant" and current is not None and msg.text.strip():
            current["a"].append(msg.text)
            current["a_ts"].append(msg.ts)
    if current is not None:
        turns.append(current)
    return turns


def turn_size(turn: dict) -> int:
    return len(turn.get("q", "")) + sum(len(item) for item in turn.get("a", []))


def split_text_blocks(text: str, max_chars: int) -> list[str]:
    text = text.strip()
    if not text:
        return [""]
    chunks = []
    current = ""
    for block in re.split(r"\n{2,}", text):
        if current:
            candidate = f"{current}\n\n{block}"
            if len(candidate) <= max_chars:
                current = candidate
                continue
            chunks.append(current)
            current = ""
        if len(block) <= max_chars:
            current = block
            continue
        start = 0
        while start < len(block):
            chunks.append(block[start:start + max_chars])
            start += max_chars
    if current:
        chunks.append(current)
    return chunks or [""]


def expand_large_turns(turns: list[dict], max_chars: int) -> list[dict]:
    expanded = []
    for turn in turns:
        if turn_size(turn) <= max_chars:
            expanded.append(turn)
            continue
        answer_text = "\n\n---\n\n".join(turn.get("a", [])).strip()
        answer_limit = max(12000, max_chars - min(len(turn.get("q", "")), max_chars // 2))
        answer_chunks = split_text_blocks(answer_text, answer_limit)
        for index, chunk in enumerate(answer_chunks):
            if index == 0:
                expanded.append({
                    "q": turn.get("q", ""),
                    "q_ts": turn.get("q_ts", ""),
                    "a": [chunk] if chunk else [],
                    "a_ts": turn.get("a_ts", []),
                })
            else:
                expanded.append({
                    "q": "Continuation of previous answer.",
                    "q_ts": "",
                    "a": [chunk] if chunk else [],
                    "a_ts": turn.get("a_ts", []),
                })
    return expanded


def split_turns(turns: list[dict], max_chars: int) -> list[list[dict]]:
    if not turns:
        return [[]]
    parts = []
    current = []
    current_size = 0
    for turn in turns:
        size = turn_size(turn)
        if current and current_size + size > max_chars:
            parts.append(current)
            current = []
            current_size = 0
        current.append(turn)
        current_size += size
    if current:
        parts.append(current)
    return parts or [[]]


def format_tool_requests(tool_requests: list[dict]) -> str:
    items = []
    for request in tool_requests:
        if not isinstance(request, dict):
            continue
        name = str(request.get("name") or "tool").strip()
        summary = str(request.get("intentionSummary") or "").strip()
        items.append(f"- {name}: {summary}" if summary else f"- {name}")
    if not items:
        return ""
    return "Requested tools:\n" + "\n".join(items)


def parse_session(session_dir: Path) -> tuple[str, str, str, list[Msg]]:
    events_path = session_dir / "events.jsonl"
    workspace_path = session_dir / "workspace.yaml"
    messages = []
    session_id = session_dir.name
    session_ts = ""
    workspace_label = session_dir.name
    if workspace_path.exists():
        try:
            for raw in workspace_path.read_text(encoding="utf-8", errors="replace").splitlines():
                if raw.startswith("repository: "):
                    workspace_label = raw.split(": ", 1)[1].strip() or workspace_label
                elif raw.startswith("cwd: ") and workspace_label == session_dir.name:
                    workspace_label = raw.split(": ", 1)[1].strip() or workspace_label
        except Exception:
            pass
    for raw in events_path.read_text(encoding="utf-8", errors="replace").splitlines():
        raw = raw.strip()
        if not raw:
            continue
        try:
            row = json.loads(raw)
        except json.JSONDecodeError:
            continue
        row_type = row.get("type")
        data = row.get("data") if isinstance(row.get("data"), dict) else {}
        ts = str(row.get("timestamp") or "")
        if row_type == "session.start":
            session_id = str(data.get("sessionId") or session_id)
            session_ts = str(data.get("startTime") or session_ts)
            continue
        if row_type == "user.message":
            content = str(data.get("content") or "").strip()
            if content:
                messages.append(Msg(role="user", text=content, ts=ts))
            continue
        if row_type == "assistant.message":
            content = str(data.get("content") or "").strip()
            if content:
                messages.append(Msg(role="assistant", text=content, ts=ts))
            else:
                tool_text = format_tool_requests(data.get("toolRequests") if isinstance(data.get("toolRequests"), list) else [])
                if tool_text:
                    messages.append(Msg(role="assistant", text=tool_text, ts=ts))
            continue
        if row_type == "tool.execution_complete":
            result = data.get("result") if isinstance(data.get("result"), dict) else {}
            tool_name = str(data.get("toolName") or "tool").strip()
            content = str(result.get("content") or "").strip()
            if content:
                messages.append(Msg(role="assistant", text=f"Tool result ({tool_name}):\n{clip_text(content)}", ts=ts))
    project_name = slugify(workspace_label, max_len=48)
    return session_id, session_ts, project_name, messages


def build_output_rel(project_name: str, session_id: str, session_ts: str, fallback_ts: float, messages: list[Msg]) -> Path:
    topic = pick_topic(messages)
    slug = slugify(topic)
    try:
        dt = datetime.fromisoformat(session_ts.replace("Z", "+00:00")) if session_ts else None
    except Exception:
        dt = None
    if dt is None:
        dt = datetime.fromtimestamp(fallback_ts, tz=timezone.utc)
    date_str = dt.date().isoformat()
    return Path(date_str[:4]) / date_str[5:7] / date_str[8:10] / f"{date_str}--{project_name}--{slug}--{session_id}.md"


def build_output_rels(base: Path, part_count: int) -> list[Path]:
    if part_count <= 1:
        return [base]
    stem = base.stem
    return [base.with_name(f"{stem}--part-{index:02d}.md") for index in range(1, part_count + 1)]


def build_markdown(session_id: str, session_ts: str, project_name: str, src: Path, out_rel: Path, turns: list[dict], part_index: int, part_count: int) -> str:
    title_topic = pick_topic([Msg("user", turn.get("q", ""), turn.get("q_ts", "")) for turn in turns if turn.get("q")]) or "conversation"
    title = f"{title_topic} - Copilot Conversation"
    if part_count > 1:
        title = f"{title} - Part {part_index}/{part_count}"
    lines = [f"# {title}", ""]
    lines.append("> [!info] Session")
    lines.append(f"- Session ID: `{session_id}`")
    if session_ts:
        lines.append(f"- Started: `{session_ts}`")
    lines.append(f"- Workspace: `{project_name}`")
    lines.append(f"- Source: `{src}`")
    lines.append(f"- File: `{out_rel}`")
    lines.append(f"- Exported: `{datetime.now(timezone.utc).isoformat()}`")
    lines.append("- Note: Copilot stores some intermediate assistant turns encrypted; only plaintext content is exported.")
    if part_count > 1:
        lines.append(f"- Part: `{part_index}/{part_count}`")
    lines.append("")
    if part_count > 1:
        lines.append("## Parts")
        lines.append("")
        part_name = out_rel.with_suffix("").as_posix()
        for idx in range(1, part_count + 1):
            target = re.sub(r"--part-\d+$", f"--part-{idx:02d}", part_name)
            lines.append(f"- Part {idx}: current" if idx == part_index else f"- [[{target}|Part {idx}]]")
        lines.append("")
    lines.append("## Navigation")
    lines.append("")
    note_name = out_rel.with_suffix("").as_posix()
    if not turns:
        lines.append("- No user/assistant messages parsed yet.")
    else:
        for idx, _turn in enumerate(turns, start=1):
            n = f"{idx:03d}"
            lines.append(f"- [[{note_name}#Q{n}|Q{n}]] -> [[{note_name}#A{n}|A{n}]]")
    lines.append("")
    for idx, turn in enumerate(turns, start=1):
        n = f"{idx:03d}"
        question = sanitize_links(turn.get("q", ""))
        answer = sanitize_links("\n\n---\n\n".join(turn.get("a", [])).strip())
        if not answer:
            answer = "_No plaintext assistant reply captured for this question._"
        lines.append(f"## Q{n}")
        lines.append("")
        lines.append(f'**My question ({turn["q_ts"]}):**' if turn.get("q_ts") else "**My question:**")
        lines.append("")
        lines.append(question)
        lines.append("")
        lines.append(f"## A{n}")
        lines.append("")
        lines.append(f'**Copilot answer ({turn["a_ts"][-1]}):**' if turn.get("a_ts") else "**Copilot answer:**")
        lines.append("")
        lines.append(answer)
        lines.append("")
        lines.append(f"Back: [[{note_name}#Navigation|Navigation]]")
        lines.append("")
    return "\n".join(lines)


def load_state() -> dict:
    if not STATE_FILE.exists():
        return {}
    try:
        return json.loads(STATE_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def save_state(state: dict) -> None:
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, ensure_ascii=False, indent=2), encoding="utf-8")


def write_if_changed(path: Path, content: str) -> bool:
    if path.exists():
        try:
            if path.read_text(encoding="utf-8") == content:
                return False
        except Exception:
            pass
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    return True


def write_index() -> bool:
    lines = ["# Copilot Conversations Index", ""]
    entries = []
    for md in sorted(OUT_ROOT.rglob("*.md")):
        if md.name == "index.md":
            continue
        rel = md.relative_to(OUT_ROOT)
        wiki = rel.with_suffix("").as_posix()
        ts = datetime.fromtimestamp(md.stat().st_mtime, tz=timezone.utc).isoformat()
        entries.append((rel.as_posix(), wiki, ts, md.stem))
    if not entries:
        lines.append("- No conversation files yet.")
    else:
        for rel_path, wiki, ts, title in entries:
            lines.append(f"- [[{wiki}|{title}]]  `{ts}`")
            lines.append(f"  - `{rel_path}`")
    lines.append("")
    return write_if_changed(OUT_ROOT / "index.md", "\n".join(lines))


def git_head() -> str:
    try:
        result = subprocess.run(
            ["git", "-C", str(VAULT_ROOT), "rev-parse", "--short", "HEAD"],
            check=True,
            capture_output=True,
            text=True,
        )
    except Exception:
        return "n/a"
    return result.stdout.strip() or "n/a"


def print_summary(scanned: int, written: int, removed: int, index_changed: bool) -> None:
    total_notes = sum(1 for md in OUT_ROOT.rglob("*.md") if md.name != "index.md")
    print(
        "copilot-obsidian-sync:",
        f"sessions_scanned={scanned}",
        f"notes_written={written}",
        f"notes_removed={removed}",
        f"index_changed={'yes' if index_changed else 'no'}",
        f"total_notes={total_notes}",
        f"vault_head={git_head()}",
    )


def main() -> None:
    OUT_ROOT.mkdir(parents=True, exist_ok=True)
    old_state = load_state()
    new_state = {}
    scanned = 0
    written = 0
    removed = 0
    if not SESSIONS_ROOT.exists():
        save_state(new_state)
        print_summary(scanned, written, removed, False)
        return
    for session_dir in sorted(SESSIONS_ROOT.iterdir()):
        if not session_dir.is_dir():
            continue
        events_path = session_dir / "events.jsonl"
        if not events_path.exists():
            continue
        try:
            stat = events_path.stat()
        except FileNotFoundError:
            continue
        scanned += 1
        key = str(events_path)
        mtime = stat.st_mtime_ns
        session_id, session_ts, project_name, messages = parse_session(session_dir)
        turns = expand_large_turns(build_turns(messages), MAX_CHARS_PER_PART)
        turn_parts = split_turns(turns, MAX_CHARS_PER_PART)
        base_rel = build_output_rel(project_name, session_id, session_ts, stat.st_mtime, messages)
        out_rels = build_output_rels(base_rel, len(turn_parts))
        prev = old_state.get(key, {})
        prev_mtime = prev.get("mtime") if isinstance(prev, dict) else None
        prev_out_rels = prev.get("out_rels") if isinstance(prev, dict) else None
        prev_version = prev.get("version", 0) if isinstance(prev, dict) else 0
        if not isinstance(prev_out_rels, list):
            prev_out_rels = []
        out_rel_strings = [path.as_posix() for path in out_rels]
        new_state[key] = {"mtime": mtime, "out_rels": out_rel_strings, "version": EXPORT_FORMAT_VERSION}
        if (
            prev_version == EXPORT_FORMAT_VERSION
            and prev_mtime == mtime
            and prev_out_rels == out_rel_strings
            and all((OUT_ROOT / item).exists() for item in out_rel_strings)
        ):
            continue
        for stale_rel in set(prev_out_rels) - set(out_rel_strings):
            old_out = OUT_ROOT / stale_rel
            if old_out.exists():
                old_out.unlink()
                removed += 1
        rel_src = events_path.relative_to(SESSIONS_ROOT)
        for part_index, (out_rel, turn_part) in enumerate(zip(out_rels, turn_parts), start=1):
            content = build_markdown(session_id, session_ts, project_name, rel_src, out_rel, turn_part, part_index, len(turn_parts))
            if write_if_changed(OUT_ROOT / out_rel, content):
                written += 1
    tracked_outputs = {
        rel
        for item in new_state.values()
        if isinstance(item, dict)
        for rel in item.get("out_rels", [])
    }
    for key, prev in old_state.items():
        if key in new_state or not isinstance(prev, dict):
            continue
        for prev_out_rel in prev.get("out_rels", []):
            if prev_out_rel and prev_out_rel not in tracked_outputs:
                old_out = OUT_ROOT / prev_out_rel
                if old_out.exists():
                    old_out.unlink()
                    removed += 1
    index_changed = write_index()
    save_state(new_state)
    print_summary(scanned, written, removed, index_changed)


if __name__ == "__main__":
    main()
