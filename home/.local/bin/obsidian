#!/usr/bin/env bash
set -euo pipefail

quarantine_file="${HOME}/.local/state/gpu-watchdog/quarantine.env"
flags=()
launch_env=(env)
args=("$@")
launch_env+=(
  ELECTRON_OZONE_PLATFORM_HINT=x11
  OZONE_PLATFORM=x11
  GDK_BACKEND=x11
)
flags+=(
  --ozone-platform=x11
)

if [[ -f "${quarantine_file}" ]]; then
  # shellcheck disable=SC1090
  source "${quarantine_file}"
fi

for f in "${flags[@]}"; do
  skip=false
  for a in "${args[@]}"; do
    if [[ "$a" == "$f" ]]; then
      skip=true
      break
    fi
    if [[ "$f" == *=* ]]; then
      key="${f%%=*}="
      if [[ "$a" == ${key}* ]]; then
        skip=true
        break
      fi
    fi
  done
  if ! $skip; then
    args+=("$f")
  fi
done

exec "${launch_env[@]}" /usr/bin/obsidian "${args[@]}"
