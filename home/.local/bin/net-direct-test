#!/usr/bin/env bash
set -euo pipefail

VPN_NAME="${VPN_NAME:-cachyOs}"

if [[ $# -eq 0 ]]; then
  printf 'Usage: %s <command> [args...]\n' "${0##*/}" >&2
  exit 64
fi

if ! command -v nmcli >/dev/null 2>&1; then
  printf 'nmcli not found\n' >&2
  exit 69
fi

was_active=0
if nmcli -t -f NAME connection show --active | grep -Fxq "$VPN_NAME"; then
  was_active=1
fi

restore_vpn() {
  if [[ "$was_active" -eq 1 ]]; then
    sudo nmcli connection up "$VPN_NAME" >/dev/null
  fi
}

trap restore_vpn EXIT INT TERM

if [[ "$was_active" -eq 1 ]]; then
  sudo nmcli connection down "$VPN_NAME" >/dev/null
fi

"$@"
