#!/usr/bin/env python3
import json
import re
import subprocess
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path

SESSIONS_ROOT = Path('/home/goringich/.codex/sessions')
OUT_ROOT = Path('/home/goringich/Desktop/Obsidian/codex-conversations')
VAULT_ROOT = Path('/home/goringich/Desktop/Obsidian')
STATE_FILE = Path('/home/goringich/.local/state/codex-obsidian-sync/state.json')
MAX_CHARS_PER_PART = 25000
EXPORT_FORMAT_VERSION = 2


@dataclass
class Msg:
    role: str
    text: str
    ts: str


LINK_RE = re.compile(r'\[([^\]]+)\]\(([^)]+)\)')
NOISE_PATTERNS = (
    'AGENTS.md instructions for',
    '<INSTRUCTIONS>',
    '<environment_context>',
    '<turn_aborted>',
)
CYRILLIC_MAP = {
    'а': 'a', 'б': 'b', 'в': 'v', 'г': 'g', 'д': 'd', 'е': 'e', 'ё': 'e', 'ж': 'zh',
    'з': 'z', 'и': 'i', 'й': 'y', 'к': 'k', 'л': 'l', 'м': 'm', 'н': 'n', 'о': 'o',
    'п': 'p', 'р': 'r', 'с': 's', 'т': 't', 'у': 'u', 'ф': 'f', 'х': 'h', 'ц': 'ts',
    'ч': 'ch', 'ш': 'sh', 'щ': 'sch', 'ъ': '', 'ы': 'y', 'ь': '', 'э': 'e', 'ю': 'yu',
    'я': 'ya',
}


def extract_text(content):
    parts = []
    if not isinstance(content, list):
        return ''
    for item in content:
        if not isinstance(item, dict):
            continue
        t = item.get('type')
        if t in ('input_text', 'output_text'):
            txt = item.get('text', '')
            if isinstance(txt, str) and txt:
                parts.append(txt)
    return '\n\n'.join(parts).strip()


def parse_session(path: Path):
    messages = []
    session_id = path.stem
    session_ts = ''

    with path.open('r', encoding='utf-8', errors='replace') as f:
        for raw in f:
            raw = raw.strip()
            if not raw:
                continue
            try:
                row = json.loads(raw)
            except json.JSONDecodeError:
                continue

            rtype = row.get('type')
            payload = row.get('payload', {})

            if rtype == 'session_meta' and isinstance(payload, dict):
                sid = payload.get('id')
                if isinstance(sid, str) and sid:
                    session_id = sid
                sts = payload.get('timestamp')
                if isinstance(sts, str):
                    session_ts = sts

            if rtype != 'response_item' or not isinstance(payload, dict):
                continue

            if payload.get('type') != 'message':
                continue

            role = payload.get('role')
            if role not in ('user', 'assistant'):
                continue

            text = extract_text(payload.get('content'))
            if not text:
                continue

            ts = row.get('timestamp', '')
            messages.append(Msg(role=role, text=text, ts=ts))

    return session_id, session_ts, messages


def cleanup_text(text: str) -> str:
    return re.sub(r'\s+', ' ', text.strip())


def is_noise_question(text: str) -> bool:
    for p in NOISE_PATTERNS:
        if p in text:
            return True
    return False


def pick_topic(messages) -> str:
    for m in messages:
        if m.role != 'user':
            continue
        t = cleanup_text(m.text)
        if not t:
            continue
        if is_noise_question(t):
            continue
        return t[:90]
    return 'conversation'


def slugify(text: str, max_len: int = 64) -> str:
    out = []
    for ch in text.lower():
        if 'a' <= ch <= 'z' or '0' <= ch <= '9':
            out.append(ch)
            continue
        if ch in CYRILLIC_MAP:
            out.append(CYRILLIC_MAP[ch])
            continue
        if ch in (' ', '-', '_', '/', '\\', '.', ',', ':', ';', '!', '?', '(', ')', '[', ']', '{', '}', '+', '=', '"', "'", '`'):
            out.append('-')
            continue
    slug = re.sub(r'-+', '-', ''.join(out)).strip('-')
    if not slug:
        slug = 'conversation'
    return slug[:max_len].strip('-') or 'conversation'


def pick_date_str(session_ts: str, src: Path) -> str:
    if session_ts:
        try:
            dt = datetime.fromisoformat(session_ts.replace('Z', '+00:00'))
            return dt.date().isoformat()
        except Exception:
            pass
    # fallback from source path: YYYY/MM/DD/file.jsonl
    parts = src.parts
    if len(parts) >= 4:
        return f'{parts[0]}-{parts[1]}-{parts[2]}'
    return datetime.now(timezone.utc).date().isoformat()


def build_output_rel(src: Path, session_id: str, session_ts: str, messages) -> Path:
    topic = pick_topic(messages)
    slug = slugify(topic)
    date_str = pick_date_str(session_ts, src)
    parts = src.parts
    if len(parts) >= 4:
        prefix = Path(parts[0]) / parts[1] / parts[2]
    else:
        prefix = Path(date_str[:4]) / date_str[5:7] / date_str[8:10]
    filename = f'{date_str}--{slug}--{session_id}.md'
    return prefix / filename


def build_output_rels(src: Path, session_id: str, session_ts: str, messages, part_count: int) -> list[Path]:
    base = build_output_rel(src, session_id, session_ts, messages)
    if part_count <= 1:
        return [base]

    stem = base.stem
    return [
        base.with_name(f'{stem}--part-{index:02d}.md')
        for index in range(1, part_count + 1)
    ]


def sanitize_links(text: str) -> str:
    """Keep only Obsidian-internal links as wiki links, flatten others to text."""
    def _repl(match):
        label = match.group(1).strip()
        target = match.group(2).strip()

        # Already wiki-style or local anchor-like forms, keep as plain label.
        if target.startswith('#'):
            return label

        # Convert absolute/relative markdown file links inside Obsidian vault to wiki links.
        p = Path(target)
        try:
            resolved = p.resolve() if p.is_absolute() else (VAULT_ROOT / p).resolve()
        except Exception:
            resolved = None

        if resolved is not None:
            try:
                rel = resolved.relative_to(VAULT_ROOT)
                if rel.suffix.lower() == '.md':
                    return f'[[{rel.with_suffix("").as_posix()}|{label}]]'
            except Exception:
                pass

        # Any other link becomes readable plain text instead of noisy markdown link.
        if label == target:
            return label
        return f'{label} ({target})'

    return LINK_RE.sub(_repl, text)


def build_turns(messages):
    turns = []
    current = None

    for m in messages:
        if m.role == 'user':
            if current is not None:
                turns.append(current)
            current = {'q': m.text, 'q_ts': m.ts, 'a': [], 'a_ts': []}
        elif m.role == 'assistant' and current is not None:
            current['a'].append(m.text)
            current['a_ts'].append(m.ts)

    if current is not None:
        turns.append(current)

    filtered = []
    for t in turns:
        q_clean = cleanup_text(t.get('q', ''))
        has_ans = bool(''.join(t.get('a', [])).strip())
        if is_noise_question(q_clean) and not has_ans:
            continue
        filtered.append(t)
    return filtered


def turn_size(turn) -> int:
    return len(turn.get('q', '')) + sum(len(item) for item in turn.get('a', []))


def split_text_blocks(text: str, max_chars: int) -> list[str]:
    text = text.strip()
    if not text:
        return ['']

    chunks = []
    current = ''
    blocks = re.split(r'\n{2,}', text)

    for block in blocks:
        if current:
            candidate = f'{current}\n\n{block}'
            if len(candidate) <= max_chars:
                current = candidate
                continue
            chunks.append(current)
            current = ''

        if len(block) <= max_chars:
            current = block
            continue

        start = 0
        while start < len(block):
            chunks.append(block[start:start + max_chars])
            start += max_chars

    if current:
        chunks.append(current)

    return chunks or ['']


def expand_large_turns(turns, max_chars: int) -> list[dict]:
    expanded = []

    for turn in turns:
        if turn_size(turn) <= max_chars:
            expanded.append(turn)
            continue

        answer_text = '\n\n---\n\n'.join(turn.get('a', [])).strip()
        answer_limit = max(12000, max_chars - min(len(turn.get('q', '')), max_chars // 2))
        answer_chunks = split_text_blocks(answer_text, answer_limit)

        for index, chunk in enumerate(answer_chunks):
            if index == 0:
                expanded.append({
                    'q': turn.get('q', ''),
                    'q_ts': turn.get('q_ts', ''),
                    'a': [chunk] if chunk else [],
                    'a_ts': turn.get('a_ts', []),
                })
            else:
                expanded.append({
                    'q': 'Continuation of previous answer.',
                    'q_ts': '',
                    'a': [chunk] if chunk else [],
                    'a_ts': turn.get('a_ts', []),
                })

    return expanded


def split_turns(turns, max_chars: int) -> list[list[dict]]:
    if not turns:
        return [[]]

    parts = []
    current = []
    current_size = 0

    for turn in turns:
        size = turn_size(turn)
        if current and current_size + size > max_chars:
            parts.append(current)
            current = []
            current_size = 0
        current.append(turn)
        current_size += size

    if current:
        parts.append(current)

    return parts or [[]]


def build_markdown(
    session_id: str,
    session_ts: str,
    src: Path,
    out_rel: Path,
    messages,
    turns,
    part_index: int = 1,
    part_count: int = 1,
):
    topic = pick_topic(messages)
    if part_count > 1:
        title = f'{topic} - Codex Conversation - Part {part_index}/{part_count}'
    else:
        title = f'{topic} - Codex Conversation'

    lines = [f'# {title}', '']
    lines.append(f'> [!info] Session')
    lines.append(f'- Session ID: `{session_id}`')
    if session_ts:
        lines.append(f'- Started: `{session_ts}`')
    lines.append(f'- Source: `{src}`')
    lines.append(f'- File: `{out_rel}`')
    lines.append(f'- Exported: `{datetime.now(timezone.utc).isoformat()}`')
    if part_count > 1:
        lines.append(f'- Part: `{part_index}/{part_count}`')
    lines.append('')

    if part_count > 1:
        lines.append('## Parts')
        lines.append('')
        part_name = out_rel.with_suffix('').as_posix()
        for idx in range(1, part_count + 1):
            target = re.sub(r'--part-\d+$', f'--part-{idx:02d}', part_name)
            if idx == part_index:
                lines.append(f'- Part {idx}: current')
            else:
                lines.append(f'- [[{target}|Part {idx}]]')
        lines.append('')

    lines.append('## Navigation')
    lines.append('')
    note_name = out_rel.with_suffix('').as_posix()
    for i, _ in enumerate(turns, start=1):
        n = f'{i:03d}'
        lines.append(f'- [[{note_name}#Q{n}|Q{n}]] -> [[{note_name}#A{n}|A{n}]]')
    if not turns:
        lines.append('- No user/assistant messages parsed yet.')
    lines.append('')

    for i, t in enumerate(turns, start=1):
        n = f'{i:03d}'
        q_text = sanitize_links(t['q'])
        ans = sanitize_links('\n\n---\n\n'.join(t['a']).strip())
        if not ans:
            ans = '_No assistant reply captured for this question._'

        lines.append(f'## Q{n}')
        lines.append('')
        if t.get('q_ts'):
            lines.append(f'**My question ({t["q_ts"]}):**')
        else:
            lines.append('**My question:**')
        lines.append('')
        lines.append(q_text)
        lines.append('')

        lines.append(f'## A{n}')
        lines.append('')
        if t.get('a_ts'):
            lines.append(f'**Codex answer ({t["a_ts"][-1]}):**')
        else:
            lines.append('**Codex answer:**')
        lines.append('')
        lines.append(ans)
        lines.append('')
        lines.append(f'Back: [[{note_name}#Navigation|Navigation]]')
        lines.append('')

    return '\n'.join(lines)


def load_state():
    if not STATE_FILE.exists():
        return {}
    try:
        return json.loads(STATE_FILE.read_text(encoding='utf-8'))
    except Exception:
        return {}


def save_state(state):
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, ensure_ascii=False, indent=2), encoding='utf-8')


def write_if_changed(path: Path, content: str) -> bool:
    if path.exists():
        try:
            existing = path.read_text(encoding='utf-8')
            if existing == content:
                return False
        except Exception:
            pass
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding='utf-8')
    return True


def write_index():
    lines = ['# Codex Conversations Index', '']

    entries = []
    for md in sorted(OUT_ROOT.rglob('*.md')):
        if md.name == 'index.md':
            continue
        rel = md.relative_to(OUT_ROOT)
        wiki = rel.with_suffix('').as_posix()
        ts = datetime.fromtimestamp(md.stat().st_mtime, tz=timezone.utc).isoformat()
        title = md.stem
        entries.append((rel.as_posix(), wiki, ts, title))

    if not entries:
        lines.append('- No conversation files yet.')
    else:
        for rel_path, wiki, ts, title in entries:
            lines.append(f'- [[{wiki}|{title}]]  `{ts}`')
            lines.append(f'  - `{rel_path}`')

    lines.append('')
    return write_if_changed(OUT_ROOT / 'index.md', '\n'.join(lines))


def git_head() -> str:
    try:
        result = subprocess.run(
            ['git', '-C', str(VAULT_ROOT), 'rev-parse', '--short', 'HEAD'],
            check=True,
            capture_output=True,
            text=True,
        )
    except Exception:
        return 'n/a'
    return result.stdout.strip() or 'n/a'


def print_summary(scanned: int, written: int, removed: int, index_changed: bool):
    total_notes = sum(1 for md in OUT_ROOT.rglob('*.md') if md.name != 'index.md')
    summary = [
        f'sessions_scanned={scanned}',
        f'notes_written={written}',
        f'notes_removed={removed}',
        f'index_changed={"yes" if index_changed else "no"}',
        f'total_notes={total_notes}',
        f'vault_head={git_head()}',
    ]
    print('codex-obsidian-sync:', ' '.join(summary))


def main():
    OUT_ROOT.mkdir(parents=True, exist_ok=True)
    old_state = load_state()
    new_state = {}
    scanned = 0
    written = 0
    removed = 0

    if not SESSIONS_ROOT.exists():
        save_state(new_state)
        print_summary(scanned, written, removed, False)
        return

    for src in sorted(SESSIONS_ROOT.rglob('*.jsonl')):
        try:
            stat = src.stat()
        except FileNotFoundError:
            continue

        scanned += 1
        rel = src.relative_to(SESSIONS_ROOT)
        key = str(src)
        mtime = stat.st_mtime_ns
        sid, sts, msgs = parse_session(src)
        turns = expand_large_turns(build_turns(msgs), MAX_CHARS_PER_PART)
        turn_parts = split_turns(turns, MAX_CHARS_PER_PART)
        out_rels = build_output_rels(rel, sid, sts, msgs, len(turn_parts))

        prev = old_state.get(key, {})
        if isinstance(prev, int):
            prev_mtime = prev
            prev_out_rels = []
            prev_version = 0
        else:
            prev_mtime = prev.get('mtime')
            prev_out_rel = prev.get('out_rel', '')
            prev_out_rels = prev.get('out_rels')
            prev_version = prev.get('version', 0)
            if not isinstance(prev_out_rels, list):
                prev_out_rels = [prev_out_rel] if prev_out_rel else []

        out_rel_strings = [path.as_posix() for path in out_rels]
        new_state[key] = {'mtime': mtime, 'out_rels': out_rel_strings, 'version': EXPORT_FORMAT_VERSION}

        if (
            prev_version == EXPORT_FORMAT_VERSION
            and prev_mtime == mtime
            and prev_out_rels == out_rel_strings
            and all((OUT_ROOT / item).exists() for item in out_rel_strings)
        ):
            continue

        stale_outputs = set(prev_out_rels) - set(out_rel_strings)
        for stale_rel in stale_outputs:
            old_out = OUT_ROOT / stale_rel
            if old_out.exists():
                old_out.unlink()
                removed += 1

        for part_index, (out_rel, turn_part) in enumerate(zip(out_rels, turn_parts), start=1):
            md = build_markdown(
                sid,
                sts,
                rel,
                out_rel,
                msgs,
                turn_part,
                part_index=part_index,
                part_count=len(turn_parts),
            )
            if write_if_changed(OUT_ROOT / out_rel, md):
                written += 1

    tracked_outputs = {
        rel
        for item in new_state.values()
        if isinstance(item, dict)
        for rel in item.get('out_rels', [])
    }
    for key, prev in old_state.items():
        if key in new_state or not isinstance(prev, dict):
            continue
        prev_out_rels = prev.get('out_rels')
        if not isinstance(prev_out_rels, list):
            prev_out_rel = prev.get('out_rel')
            prev_out_rels = [prev_out_rel] if prev_out_rel else []
        for prev_out_rel in prev_out_rels:
            if not prev_out_rel or prev_out_rel in tracked_outputs:
                continue
            old_out = OUT_ROOT / prev_out_rel
            if old_out.exists():
                old_out.unlink()
                removed += 1

    index_changed = write_index()
    save_state(new_state)
    print_summary(scanned, written, removed, index_changed)


if __name__ == '__main__':
    main()
