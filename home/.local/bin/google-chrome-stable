#!/usr/bin/env bash
# Wrapper to keep Chrome on stable Wayland defaults and avoid aggressive
# GPU/video flags that can increase load on unstable NVIDIA stacks.
# Avoid duplicate flags if user passes their own.

set -euo pipefail

default_profile="Default"
quarantine_file="${HOME}/.local/state/gpu-watchdog/quarantine.env"
scale_state="${HOME}/__home_organized/runtime/hypr-scaling/current.env"
chrome_scale="1"

if [[ -f "${scale_state}" ]]; then
  # shellcheck disable=SC1090
  source "${scale_state}"
  chrome_scale="${HYPR_CHROME_DEVICE_SCALE:-${chrome_scale}}"
fi

flags=(
  --profile-directory=${default_profile}
  --disable-features=UseChromeOSDirectVideoDecoder
  --disable-background-mode
)

# Native Wayland Chrome on NVIDIA has been unstable here and can come up
# without working WebGL. Default to XWayland unless explicitly overridden.
if [[ "${CHROME_FORCE_WAYLAND:-0}" == "1" ]]; then
  flags+=(
    --ozone-platform-hint=auto
    --enable-features=UseOzonePlatform,WaylandWindowDecorations,WebRTCPipeWireCapturer
  )
else
  flags+=(
    --ozone-platform=x11
    --disable-features=UseOzonePlatform
    --force-device-scale-factor=${chrome_scale}
  )
fi

args=("$@")
if [[ -f "${quarantine_file}" ]]; then
  # shellcheck disable=SC1090
  source "${quarantine_file}"
fi
for f in "${flags[@]}"; do
  skip=false
  for a in "${args[@]}"; do
    # Match exact flag or same key with any value when flag has '='
    if [[ "$a" == "$f" ]]; then
      skip=true; break
    fi
    if [[ "$f" == *=* ]]; then
      key="${f%%=*}="
      if [[ "$a" == ${key}* ]]; then
        skip=true; break
      fi
    fi
    if [[ "$a" == --enable-features=* && "$f" == --enable-features=* ]]; then
      # Merge enable-features lists to avoid overwriting
      base="${a#--enable-features=}"
      add="${f#--enable-features=}"
      merged=$(printf "%s,%s\n" "$base" "$add" | awk -v RS=',' '!seen[$0]++' ORS=',' | sed 's/,$//')
      # Replace in-place
      for i in "${!args[@]}"; do
        if [[ "${args[$i]}" == "$a" ]]; then
          args[$i]="--enable-features=${merged}"
          skip=true
          break
        fi
      done
    fi
    if [[ "$a" == --disable-features=* && "$f" == --disable-features=* ]]; then
      base="${a#--disable-features=}"
      add="${f#--disable-features=}"
      merged=$(printf "%s,%s\n" "$base" "$add" | awk -v RS=',' '!seen[$0]++' ORS=',' | sed 's/,$//')
      for i in "${!args[@]}"; do
        if [[ "${args[$i]}" == "$a" ]]; then
          args[$i]="--disable-features=${merged}"
          skip=true
          break
        fi
      done
    fi
  done
  if ! $skip; then
    args+=("$f")
  fi
done

# Lower CPU/IO priority a bit to reduce startup heat spikes.
exec ionice -c2 -n7 nice -n 5 /usr/bin/google-chrome-stable "${args[@]}"
