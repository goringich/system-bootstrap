#!/usr/bin/env bash
# quiet + workarounds for Electron on Wayland
export ELECTRON_DISABLE_SECURITY_WARNINGS=1
export ELECTRON_ENABLE_LOGGING=false
export NO_AT_BRIDGE=1

DISCORD_BIN="/usr/bin/discord"
if [ ! -x "${DISCORD_BIN}" ]; then
  DISCORD_BIN="${HOME}/.local/opt/discord/current/Discord"
fi

exec "${DISCORD_BIN}" \
  --no-sandbox \
  --disable-extensions \
  --disable-logging \
  --ozone-platform-hint=auto \
  >/dev/null 2>&1 &
