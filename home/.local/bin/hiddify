#!/usr/bin/env bash
set -euo pipefail

runtime_dir="${HOME}/__home_organized/artifacts/hiddify/current"
binary="${runtime_dir}/hiddify"
lib_dir="${runtime_dir}/usr/lib"

if [[ ! -x "${binary}" ]]; then
    printf 'Hiddify runtime is missing. Run %s first.\n' "${HOME}/__home_organized/scripts/hiddify-install-update.sh" >&2
    exit 1
fi

cd "${runtime_dir}"
exec env LD_LIBRARY_PATH="${lib_dir}" "${binary}" "$@"
