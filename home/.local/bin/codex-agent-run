#!/usr/bin/env bash
set -euo pipefail

RUNTIME_ROOT="${CODEX_ORCHESTRATOR_ROOT:-$HOME/__home_organized/runtime/codex-orchestrator}"
QUEUE_DIR="$RUNTIME_ROOT/queue"
CLAIMS_DIR="$RUNTIME_ROOT/claims"
DONE_DIR="$RUNTIME_ROOT/done"
FAILED_DIR="$RUNTIME_ROOT/failed"
ARTIFACT_ROOT="${CODEX_ORCHESTRATOR_ARTIFACTS:-$HOME/__home_organized/artifacts/codex-orchestrator}"
LOG_ROOT="${CODEX_ORCHESTRATOR_LOGS:-$HOME/__home_organized/logs/codex-orchestrator}"
MANAGER_PROMPT_FILE="${CODEX_ORCHESTRATOR_MANAGER_PROMPT:-$HOME/.config/codex-orchestrator/manager-prompt.txt}"
DEFAULT_SANDBOX="${CODEX_ORCHESTRATOR_SANDBOX:-workspace-write}"

mkdir -p "$QUEUE_DIR" "$CLAIMS_DIR" "$DONE_DIR" "$FAILED_DIR" "$ARTIFACT_ROOT" "$LOG_ROOT"

task_file="$(find "$QUEUE_DIR" -maxdepth 1 -type f -name '*.task' | sort | head -n 1)"
if [[ -z "${task_file:-}" ]]; then
  echo "No queued tasks"
  exit 0
fi

task_base="$(basename "$task_file")"
task_id="${task_base%.task}"
claim_file="$CLAIMS_DIR/$task_base.running"
mv "$task_file" "$claim_file"

cleanup_on_error() {
  local exit_code="$1"
  if [[ "$exit_code" -ne 0 && -f "$claim_file" ]]; then
    mv "$claim_file" "$FAILED_DIR/$task_base.failed"
  fi
}
trap 'cleanup_on_error $?' EXIT

timestamp="$(date +%Y%m%d-%H%M%S)"
task_artifact_dir="$ARTIFACT_ROOT/$timestamp-$task_id"
mkdir -p "$task_artifact_dir"

title="$task_id"
workdir="$HOME"
sandbox="$DEFAULT_SANDBOX"
skip_git_repo_check="false"
declare -a add_dirs=()

prompt_body_file="$task_artifact_dir/task-prompt.txt"
combined_prompt_file="$task_artifact_dir/combined-prompt.txt"
output_last_message="$task_artifact_dir/final-message.txt"
json_log="$LOG_ROOT/$timestamp-$task_id.jsonl"
header_file="$task_artifact_dir/header.txt"

header_mode="true"
: > "$header_file"
: > "$prompt_body_file"
while IFS= read -r line || [[ -n "$line" ]]; do
  if [[ "$header_mode" == "true" && "$line" == "---" ]]; then
    header_mode="false"
    continue
  fi
  if [[ "$header_mode" == "true" ]]; then
    printf '%s\n' "$line" >> "$header_file"
  else
    printf '%s\n' "$line" >> "$prompt_body_file"
  fi
done < "$claim_file"

while IFS= read -r line; do
  [[ -n "$line" ]] || continue
  key="${line%%:*}"
  value="$(printf '%s' "${line#*:}" | sed 's/^ *//')"
  case "$key" in
    title) title="$value" ;;
    workdir) workdir="$value" ;;
    sandbox) sandbox="$value" ;;
    add_dir) add_dirs+=("$value") ;;
    skip_git_repo_check) skip_git_repo_check="$value" ;;
  esac
done < "$task_artifact_dir/header.txt"

{
  cat "$MANAGER_PROMPT_FILE"
  printf '\n\nTask title: %s\n\n' "$title"
  cat "$prompt_body_file"
} > "$combined_prompt_file"

cmd=(codex exec --full-auto -C "$workdir" -s "$sandbox" --output-last-message "$output_last_message" --json -)
if [[ "$skip_git_repo_check" == "true" ]]; then
  cmd+=(--skip-git-repo-check)
fi
for dir in "${add_dirs[@]}"; do
  cmd+=(--add-dir "$dir")
done

echo "Running task: $title"
set +e
"${cmd[@]}" < "$combined_prompt_file" > "$json_log" 2>&1
exit_code=$?
set -e

summary_file="$task_artifact_dir/summary.txt"
{
  printf 'title=%s\n' "$title"
  printf 'workdir=%s\n' "$workdir"
  printf 'sandbox=%s\n' "$sandbox"
  printf 'exit_code=%s\n' "$exit_code"
  printf 'json_log=%s\n' "$json_log"
  printf 'final_message=%s\n' "$output_last_message"
} > "$summary_file"

if [[ "$exit_code" -eq 0 ]]; then
  mv "$claim_file" "$DONE_DIR/$task_base.done"
else
  mv "$claim_file" "$FAILED_DIR/$task_base.failed"
fi

trap - EXIT

exit "$exit_code"
